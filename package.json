{
  "name": "linklet",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc && parcel build src/index.html --dist-dir public",
    "start": "ENV=prod node dist/server.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:client": "parcel src/index.html --port 3000",
    "format": "prettier --write \"src/**/*.{ts,tsx,mjs}\" \"src/**/*.{ts,tsx,mjs}\""
  },
  "prettier": {
    "singleQuote": true,
    "semi": true,
    "tabWidth": 2,
    "printWidth": 80,
    "trailingComma": "es5"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.980.0",
    "@aws-sdk/lib-dynamodb": "^3.980.0",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "lucide-react": "^0.564.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@parcel/config-default": "^2.16.4",
    "@parcel/transformer-css": "^2.16.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "22.15",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "parcel": "^2.16.4",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
